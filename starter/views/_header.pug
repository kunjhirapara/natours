header.header
  nav.nav.nav--tours
    a.nav__el(href='/') All tours
    //- form(class='nav__search')
    //-   button(class='nav__search-btn')
    //-     svg
    //-       use(xlink:href='img/icons.svg#icon-search')
    //-   input(type='text' placeholder='Search tours' class='nav__search-input')
  .header__logo
    img(src='/img/logo-white.png', alt='Natours logo')
  nav.nav.nav--user
    if user
      a.nav__el(href='#')
        img.nav__user-img(
          src=`/img/users/${user.photo}`,
          alt=`pictur of ${user.name}`
        )
        span= user.name.split(' ')[0]
      button.nav__el.nav__el--logout Log out
    else
      a.nav__el(href='/login') Log in
      a.nav__el.nav__el--cta(href='#') Sign up
